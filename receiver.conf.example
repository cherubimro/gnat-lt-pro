# =============================================================================
# gnat-lt-pro receiver_stream daemon configuration (example)
# =============================================================================
# Format: one `key = value` per line; `#` starts a comment; surrounding
# whitespace is trimmed.  Copy to e.g. /etc/lt-diode/receiver.conf and start:
#
#     receiver_stream --config /etc/lt-diode/receiver.conf
#
# PRECEDENCE (low -> high):  built-in defaults  <  this file  <  positional CLI
# args.  With port/spool/seed all set here the positional args are optional.
# =============================================================================

# --- Transport ---------------------------------------------------------------
# UDP port to listen on (single port; this port unifies what the C reference
# split across three).  Must match the sender.  REQUIRED.
port = 9000

# Shared LT seed.  MUST be identical on the sender and receiver.  REQUIRED.
seed = 42

# Expected channel loss %, for CLI parity with the sender.  The receiver decodes
# from whatever arrives, so this is informational here.
loss = 30

# --- Spool / output ----------------------------------------------------------
# Directory the decoded output files, their .finished / .corrupt markers, and
# verify.log live in.  REQUIRED.
spool = /var/lib/lt-diode/incoming

# Path of the per-transfer verdict journal.  Default: <spool>/verify.log
# verify_log = /var/log/lt-diode/verify.log

# --- Parallelism / timeouts --------------------------------------------------
# Max concurrent transfers (distinct FILEIDs) decoding at once; clamped to the
# compile-time ceiling (16).  The group-state pool (~32 MB/state, ~2x this) is
# allocated at start-up, so raising this raises RAM.  Default 3.  --max-inflight.
# max_inflight = 3

# Seconds of inactivity before a stalled transfer (lost trailer) is evicted as
# .corrupt.  Default 10.  --evict-timeout.
# evict_timeout = 10

# --- Operational logging (timestamp + level) ---------------------------------
# Where the [rs] operational lines go: stderr (default; journald timestamps it
# under systemd) | file | syslog.  --syslog / --log <file> on the CLI override.
# log_dest  = stderr
# log_file  = /var/log/lt-diode/receiver.log      # when log_dest = file
# log_level = info                                # debug | info | warn | error
